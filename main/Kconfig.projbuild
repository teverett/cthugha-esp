menu "Cthugha Configuration"

    menu "LCD Display"
        config CTHUGHA_LCD_BL_GPIO
            int "Backlight GPIO number"
            default 26

        config CTHUGHA_LCD_RST_GPIO
            int "LCD reset GPIO number"
            default 27
    endmenu

    menu "I2S Microphone"
        config CTHUGHA_I2S_NUM
            int "I2S peripheral number"
            default 0

        config CTHUGHA_I2S_MCLK_GPIO
            int "I2S master clock GPIO"
            default 13

        config CTHUGHA_I2S_BCK_GPIO
            int "I2S bit clock GPIO"
            default 12

        config CTHUGHA_I2S_WS_GPIO
            int "I2S word select GPIO"
            default 10

        config CTHUGHA_I2S_DIN_GPIO
            int "I2S data in GPIO"
            default 11

        config CTHUGHA_I2S_DOUT_GPIO
            int "I2S data out GPIO (codec DAC)"
            default 9

        config CTHUGHA_I2S_SAMPLE_RATE
            int "Sample rate (Hz)"
            default 16000
    endmenu

    menu "I2C Touch"
        config CTHUGHA_TOUCH_I2C_NUM
            int "I2C peripheral number"
            default 0

        config CTHUGHA_TOUCH_I2C_SDA_GPIO
            int "I2C SDA GPIO"
            default 7

        config CTHUGHA_TOUCH_I2C_SCL_GPIO
            int "I2C SCL GPIO"
            default 8

        config CTHUGHA_TOUCH_RST_GPIO
            int "Touch reset GPIO"
            default 5

        config CTHUGHA_TOUCH_INT_GPIO
            int "Touch interrupt GPIO"
            default 6
    endmenu

endmenu
